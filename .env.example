# WordPress.org SVN deploy credentials.
#
# These are NOT loaded at runtime — this file only documents the values the
# GitHub Actions deploy workflow needs. Put the real values in GitHub repo
# secrets, NEVER commit them:
#
#   GitHub repo -> Settings -> Secrets and variables -> Actions -> New repository secret
#
# Create two secrets with these exact names:

# Your WordPress.org username (case-sensitive).
SVN_USERNAME=levskipg

# A WordPress.org SVN password. Generate it at:
#   https://wordpress.org/support/users/levskipg/  ->  Account & Security
# (This is a dedicated SVN password, not your wordpress.org login password.)
SVN_PASSWORD=your-wordpress-org-svn-password
